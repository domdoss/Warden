{
  "name": "dockbox",
  "version": "1.2.14",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:agent-runner",
    "build:agent-runner": "cd container/agent-runner && npx tsc --outDir ../../dist/agent-runner --skipLibCheck --strict false",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "compress-photos": "node compress-photos.cjs",
    "voice": "cd voice && uv run main.py"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "basic-ftp": "^5.2.0",
    "better-sqlite3": "^12.11.1",
    "cron-parser": "^5.5.0",
    "grammy": "^1.39.3",
    "http-proxy": "^1.18.1",
    "imapflow": "^1.2.13",
    "mammoth": "^1.12.0",
    "node-pty": "^1.0.0",
    "nodemailer": "^8.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "playwright-core": "1.61.1",
    "glob": "^10.5.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@types/better-sqlite3": "^7.6.12",
    "@types/glob": "^8.1.0",
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode-terminal": "^0.12.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "pdfjs-dist": "^5.5.207",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "@whiskeysockets/baileys@7.0.0-rc13": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "node-pty@1.1.0": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true
  }
}
