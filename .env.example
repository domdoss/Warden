# === Assistant ===
ASSISTANT_NAME=Mirific
ADMIN_PASSWORD=mirific          # Dashboard admin password

# === Channels (enable by adding credentials) ===
# TELEGRAM_BOT_TOKEN=         # From @BotFather
# ASSISTANT_HAS_OWN_NUMBER=   # Set to 'true' if WhatsApp bot has its own phone number
# SLACK_BOT_TOKEN=             # Slack bot token (xoxb-...) — see wiki for setup
# SLACK_TEAM_ID=               # Slack workspace team ID (T...)

# === Ollama (for PII scrubbing) ===
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=granite4:latest
OLLAMA_CHAT_MODEL=llama3.2:latest    # Model for chat responses (local/hybrid mode)
LOCAL_ASSISTANT_NAME=Kimi             # Bot name when using local model (default: Kimi)
DEFAULT_MODEL_MODE=                   # "" (Ollama only), "local", "hybrid"

# === Voice Transcription ===
# WHISPER_URL=http://127.0.0.1:8000
# WHISPER_MODEL=whisper-large-v3-turbo

# === Optional ===
# PARALLEL_API_KEY=            # Parallel AI for web research
# OPENAI_API_KEY=              # OpenAI API (alternative transcription)
# STATUS_PORT=3200             # Dashboard port (default: 3200)
# TZ=                          # Timezone (auto-detected if not set)
# IDLE_TIMEOUT=1800000         # Container idle timeout in ms (default: 30 min)
# MAX_CONCURRENT_CONTAINERS=8  # Max simultaneous agent containers
